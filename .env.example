# ── Database ─────────────────────────────────────────────
POSTGRES_USER=kyrgpulse
POSTGRES_PASSWORD=kyrgpulse123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kyrgpulse_db

# ── Parsing ───────────────────────────────────────────────
CITY=bishkek
MAX_PAGES=10
HEADLESS=true
SLOW_MO=800

# ── Celery / Redis ────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── API CORS ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────
# Browser-side (public): http://localhost:8000/api for dev / public URL for prod
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Server-side SSR URL (container-to-container, not exposed to browser)
API_INTERNAL_URL=http://backend:8000/api

# ── Admin panel ───────────────────────────────────────────
# Password to access /admin. Set something strong in production.
ADMIN_PASSWORD=changeme

# ── Telegram Bot (optional) ───────────────────────────────
# Get token from @BotFather. Username without @.
TELEGRAM_BOT_TOKEN=8807872211:AAGxMtRVDG44el5pg1MoD2QOz739Q7Xt7s8
TELEGRAM_BOT_USERNAME=t.me/kyrgpulse_bot
