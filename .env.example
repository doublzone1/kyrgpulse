# ── Database ─────────────────────────────────────────────
# Railway: automatically set as DATABASE_URL (use that instead)
POSTGRES_USER=kyrgpulse
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kyrgpulse_db

# ── Parsing ───────────────────────────────────────────────
CITY=bishkek
MAX_PAGES=10
HEADLESS=true
SLOW_MO=800

# ── Celery / Redis ────────────────────────────────────────
# Railway: use the Redis service URL from Railway dashboard
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── API CORS ──────────────────────────────────────────────
# Production: set to your Netlify URL, e.g. https://kyrgpulse.netlify.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────
# Production: set to your Railway backend URL, e.g. https://kyrgpulse-backend.up.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Admin panel ───────────────────────────────────────────
ADMIN_PASSWORD=change_me_in_production

# ── Telegram Bot (optional) ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Monitoring (optional) ────────────────────────────────
SENTRY_DSN=
TELEGRAM_ADMIN_CHAT_ID=
